# Konfigurasi Database MySQL Lokal
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=culturestone

# JWT Secret (GANTI dengan secret yang kuat di production!)
API_SECRET=CULTURESTONE_JWT_SECRET_2024_SUPER_AMAN

# Port Server (default 8080)
PORT=8080

# BUG-10 FIX: Base URL untuk akses file yang diupload secara lokal
# Ganti ke domain asli saat production (contoh: https://yourdomain.com)
BASE_URL=http://localhost:8080

# ============================================================
# Akun Admin Tetap (Auto-seed saat backend pertama kali jalan)
# GANTI username dan password sesuai kebutuhan Anda.
# Password HARUS: min 8 karakter, ada huruf besar, huruf kecil, dan angka.
# Contoh password kuat: CultStone2024
# ============================================================
ADMIN_USERNAME=adminculturestone
ADMIN_PASSWORD=Culturestone2025
