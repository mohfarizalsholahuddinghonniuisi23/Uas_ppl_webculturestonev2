# ============================================
# TEMPLATE KONFIGURASI BACKEND CULTURESTONE
# ============================================
# Salin file ini menjadi .env dan sesuaikan nilainya

# --- Database MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=          # Isi dengan password MySQL Anda (kosongkan jika tidak ada password)
DB_NAME=culturestone

# --- JWT Secret (jangan ubah ini agar token tetap valid) ---
API_SECRET=CULTURESTONE_JWT_SECRET_2024_SUPER_AMAN

# --- Port Server (default 8080) ---
PORT=8080

# --- Base URL (untuk akses file upload lokal) ---
BASE_URL=http://localhost:8080
